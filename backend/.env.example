# Google Cloud Project ID (required)
GOOGLE_CLOUD_PROJECT=genai-cert-apac-project

# Gemini model to use via Vertex AI or AI Studio
# Options: gemini-2.0-flash-exp, gemini-1.5-pro-latest, gemini-2.0-flash
GOOGLE_ADK_MODEL=gemini-3.1-flash-lite-preview

# Choose this if you're using Vertex AI
# GOOGLE_GENAI_USE_VERTEXAI=True

# Choose this if you're using AI Google API Key
GOOGLE_API_KEY=insert-your-api-key-here
GEMINI_API_KEY=insert-your-api-key-here

# Application environment
ENVIRONMENT=development

# CORS allowed origins (comma-separated)
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# SQLite MCP database path (used for decision matrices)
SQLITE_DB_PATH=:memory:

# Optional: Firestore emulator for local dev
# FIRESTORE_EMULATOR_HOST=localhost:8080
